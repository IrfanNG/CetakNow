# CetakNow Environment Variables
# Copy this file to .env and fill in the values.

# Node environment
NODE_ENV=development

# PostgreSQL connection string
# Leave unset to use local JSON fallback (data/db.json)
DATABASE_URL=postgresql://user:password@localhost:5432/cetaknow

# PostgreSQL SSL mode (set to "require" on Railway)
PGSSLMODE=disable

# Upload directory for PDF files
# On Railway with a mounted volume: /data/pdfs
# Locally: defaults to storage/pdfs/
UPLOAD_DIR=storage/pdfs

# Session secret (generate a long random string)
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Server port (defaults to 3000)
PORT=3000

# Server host (defaults to 127.0.0.1)
HOST=0.0.0.0
